/*
 * BUG BISECTION: Find minimal trigger
 *
 * Hypothesis: Bug triggered by:
 * - Array BEFORE ADDRESS variables affects stack offset calculation
 * - After CALL, the return address restoration uses wrong offset
 */

MON1: PROCEDURE(FUNC, PARM) EXTERNAL;
    DECLARE FUNC BYTE, PARM ADDRESS;
END MON1;

DECLARE CONOUT LITERALLY '2';

PRINTCHAR: PROCEDURE(C);
    DECLARE C BYTE;
    CALL MON1(CONOUT, C);
END PRINTCHAR;

PRINTHEX: PROCEDURE(N);
    DECLARE N BYTE;
    DECLARE HEX DATA('0123456789ABCDEF');
    CALL PRINTCHAR(HEX(SHR(N, 4)));
    CALL PRINTCHAR(HEX(N AND 0FH));
END PRINTHEX;

DECLARE GBUF$PTR ADDRESS;
DECLARE GBUF BASED GBUF$PTR (256) BYTE;

INNER: PROCEDURE BYTE;
    DECLARE I BYTE;
    I = 0;
    DO WHILE I < 10;
        I = I + 1;
    END;
    RETURN 1;
END INNER;

/* Test A: Array BEFORE ADDRESS variables */
TEST$A: PROCEDURE;
    DECLARE ARR (36) BYTE;  /* Array first */
    DECLARE V1 ADDRESS;     /* Then ADDRESS */
    DECLARE V2 ADDRESS;
    DECLARE RESULT BYTE;

    ARR(0) = 'X';
    V1 = 1;
    V2 = 4;

    CALL PRINTCHAR('A');
    CALL PRINTCHAR('<');
    CALL PRINTHEX(LOW(V1));
    CALL PRINTHEX(LOW(V2));

    RESULT = INNER;

    CALL PRINTCHAR('>');
    CALL PRINTHEX(LOW(V1));
    CALL PRINTHEX(LOW(V2));

    IF V1 = 1 AND V2 = 4 THEN CALL PRINTCHAR('P');
    ELSE CALL PRINTCHAR('F');
    CALL PRINTCHAR(13);
    CALL PRINTCHAR(10);
END TEST$A;

/* Test B: ADDRESS variables BEFORE array */
TEST$B: PROCEDURE;
    DECLARE V1 ADDRESS;     /* ADDRESS first */
    DECLARE V2 ADDRESS;
    DECLARE ARR (36) BYTE;  /* Then array */
    DECLARE RESULT BYTE;

    V1 = 1;
    V2 = 4;
    ARR(0) = 'X';

    CALL PRINTCHAR('B');
    CALL PRINTCHAR('<');
    CALL PRINTHEX(LOW(V1));
    CALL PRINTHEX(LOW(V2));

    RESULT = INNER;

    CALL PRINTCHAR('>');
    CALL PRINTHEX(LOW(V1));
    CALL PRINTHEX(LOW(V2));

    IF V1 = 1 AND V2 = 4 THEN CALL PRINTCHAR('P');
    ELSE CALL PRINTCHAR('F');
    CALL PRINTCHAR(13);
    CALL PRINTCHAR(10);
END TEST$B;

/* Test C: No array, just ADDRESS variables */
TEST$C: PROCEDURE;
    DECLARE V1 ADDRESS;
    DECLARE V2 ADDRESS;
    DECLARE V3 ADDRESS;
    DECLARE V4 ADDRESS;
    DECLARE V5 ADDRESS;
    DECLARE RESULT BYTE;

    V1 = 1;
    V2 = 4;
    V3 = 0;
    V4 = 0;
    V5 = 0;

    CALL PRINTCHAR('C');
    CALL PRINTCHAR('<');
    CALL PRINTHEX(LOW(V1));
    CALL PRINTHEX(LOW(V2));

    RESULT = INNER;

    CALL PRINTCHAR('>');
    CALL PRINTHEX(LOW(V1));
    CALL PRINTHEX(LOW(V2));

    IF V1 = 1 AND V2 = 4 THEN CALL PRINTCHAR('P');
    ELSE CALL PRINTCHAR('F');
    CALL PRINTCHAR(13);
    CALL PRINTCHAR(10);
END TEST$C;

/* Test D: Array before + many ADDRESS + BASED pointer */
TEST$D: PROCEDURE;
    DECLARE ARR (36) BYTE;
    DECLARE V1 ADDRESS;
    DECLARE V2 ADDRESS;
    DECLARE V3 ADDRESS;
    DECLARE V4 ADDRESS;
    DECLARE PTR ADDRESS;
    DECLARE ENT BASED PTR (32) BYTE;
    DECLARE RESULT BYTE;

    ARR(0) = 'X';
    V1 = 1;
    V2 = 4;
    V3 = 0;
    V4 = 0;
    PTR = GBUF$PTR;

    CALL PRINTCHAR('D');
    CALL PRINTCHAR('<');
    CALL PRINTHEX(LOW(V1));
    CALL PRINTHEX(LOW(V2));

    /* Use BASED pointer */
    V3 = ENT(0);

    RESULT = INNER;

    CALL PRINTCHAR('>');
    CALL PRINTHEX(LOW(V1));
    CALL PRINTHEX(LOW(V2));

    IF V1 = 1 AND V2 = 4 THEN CALL PRINTCHAR('P');
    ELSE CALL PRINTCHAR('F');
    CALL PRINTCHAR(13);
    CALL PRINTCHAR(10);
END TEST$D;

DECLARE BUFFER (256) BYTE;
DECLARE I BYTE;

GBUF$PTR = .BUFFER;
I = 0;
DO WHILE I < 128;
    BUFFER(I) = 0;
    I = I + 1;
END;

CALL TEST$A;
CALL TEST$B;
CALL TEST$C;
CALL TEST$D;

EOF
