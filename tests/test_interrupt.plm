/*
 * TEST INTERRUPT PROCEDURE ATTRIBUTE
 *
 * Tests PROCEDURE INTERRUPT n; declaration syntax.
 *
 * Note: Full interrupt testing with hardware RST vectors requires bare metal
 * mode. This test verifies the procedure definition and calling works correctly.
 * The INTERRUPT attribute causes the compiler to:
 * 1. Save all registers at procedure entry
 * 2. Restore all registers before return
 * 3. Use EI + RET instead of just RET
 *
 * BUILD:
 *   python -m uplm80.compiler tests/test_interrupt.plm -o tests/build/test_interrupt.mac
 *   um80 tests/build/test_interrupt.mac
 *   ul80 -o tests/build/test_interrupt.com tests/build/test_interrupt.rel tests/test_stubs.rel
 *   cpmemu tests/build/test_interrupt.com
 */

0100H:  /* CP/M ORIGIN */

TEST$INTERRUPT:
DO;

DECLARE CR LITERALLY '13';
DECLARE LF LITERALLY '10';

/* CP/M BDOS INTERFACE */
MON1: PROCEDURE(FUNC, PARM) EXTERNAL;
    DECLARE FUNC BYTE, PARM ADDRESS;
END MON1;

/* PRINT SINGLE CHARACTER */
PRINT$CHAR: PROCEDURE(C);
    DECLARE C BYTE;
    CALL MON1(2, C);
END PRINT$CHAR;

/* PRINT STRING TERMINATED BY '$' */
PRINT$STR: PROCEDURE(S);
    DECLARE S ADDRESS;
    CALL MON1(9, S);
END PRINT$STR;

/* PRINT NEWLINE */
CRLF: PROCEDURE;
    CALL PRINT$CHAR(CR);
    CALL PRINT$CHAR(LF);
END CRLF;

/* PRINT DECIMAL NUMBER */
PRINT$NUM: PROCEDURE(N);
    DECLARE N ADDRESS;
    DECLARE BUFFER(6) BYTE;
    DECLARE I BYTE;

    IF N = 0 THEN DO;
        CALL PRINT$CHAR('0');
        RETURN;
    END;

    I = 0;
    DO WHILE N > 0;
        BUFFER(I) = (N MOD 10) + '0';
        N = N / 10;
        I = I + 1;
    END;

    DO WHILE I > 0;
        I = I - 1;
        CALL PRINT$CHAR(BUFFER(I));
    END;
END PRINT$NUM;

/* PRINT TEST RESULT */
PRINT$TEST: PROCEDURE(NAME, VALUE);
    DECLARE NAME ADDRESS;
    DECLARE VALUE ADDRESS;
    CALL PRINT$STR(NAME);
    CALL PRINT$CHAR(' ');
    CALL PRINT$NUM(VALUE);
    CALL CRLF;
END PRINT$TEST;

/* ================================================================
 * INTERRUPT HANDLER PROCEDURE
 *
 * This procedure uses the INTERRUPT attribute which causes the
 * compiler to save/restore all registers and use EI+RET.
 *
 * INTERRUPT 3 means this handles RST 3 (address 0018H).
 * The procedure can also be called normally.
 * ================================================================ */

DECLARE INT$COUNT ADDRESS;

HANDLE$INT: PROCEDURE INTERRUPT 3;
    INT$COUNT = INT$COUNT + 1;
END HANDLE$INT;

/* ================================================================
 * TEST 1: INTERRUPT PROCEDURE CAN BE CALLED DIRECTLY
 *
 * An interrupt procedure works like a normal procedure when called.
 * ================================================================ */

INT$COUNT = 0;
CALL HANDLE$INT;
CALL HANDLE$INT;
CALL HANDLE$INT;
CALL PRINT$TEST(.'int_call $', INT$COUNT);  /* Expected: 3 */

/* ================================================================
 * TEST 2: MULTIPLE INTERRUPT PROCEDURES
 *
 * Test that multiple interrupt handlers can be defined.
 * ================================================================ */

DECLARE INT2$COUNT ADDRESS;

HANDLE$INT2: PROCEDURE INTERRUPT 5;
    INT2$COUNT = INT2$COUNT + 1;
END HANDLE$INT2;

INT2$COUNT = 0;
CALL HANDLE$INT2;
CALL HANDLE$INT2;
CALL PRINT$TEST(.'int2_call $', INT2$COUNT);  /* Expected: 2 */

/* ================================================================
 * TEST 3: INTERRUPT HANDLER PRESERVES STATE
 *
 * Since interrupt handlers push/pop all registers, the state
 * before and after should be identical. We test by doing a
 * calculation across multiple calls.
 * ================================================================ */

DECLARE (A, B) ADDRESS;
A = 12345;
B = 0;

DECLARE I ADDRESS;
DO I = 0 TO 100;
    B = B + A;
    CALL HANDLE$INT;  /* This should not corrupt any registers */
END;

/* 101 * 12345 = 1246845 mod 65536 = 1661 */
CALL PRINT$TEST(.'int_preserve $', B);  /* Expected: 1661 */

/* ================================================================
 * TEST 4: VERIFY COUNTER INCREMENTS
 *
 * Check that the interrupt counter is correct after all the calls.
 * ================================================================ */

/* INT$COUNT was 3 after test 1, plus 101 calls in test 3 */
CALL PRINT$TEST(.'int_total $', INT$COUNT);  /* Expected: 104 */

END TEST$INTERRUPT;
