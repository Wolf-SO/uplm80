/*
 * TEST: LITERALLY MACRO EXPANSION (Bug c05cd81 regression test)
 *
 * Tests LITERALLY macro expansion in various contexts:
 * - Structure member dimensions like `fcb(frsize) byte` where frsize is LITERALLY
 * - INTERRUPT numbers in procedure declarations
 * - Array dimensions
 * - Constant expressions
 *
 * BUILD:
 *   python -m uplm80.compiler tests/test_literally.plm -o tests/build/test_literally.mac
 *   um80 tests/build/test_literally.mac -o tests/build/test_literally.rel
 *   ul80 -o tests/build/test_literally.com tests/build/test_literally.rel
 *   cpmemu tests/build/test_literally.com
 */

0100H:

TEST$LITERALLY:
DO;

DECLARE CR LITERALLY '13';
DECLARE LF LITERALLY '10';

/* CP/M BDOS */
MON1: PROCEDURE(FUNC, PARM) EXTERNAL;
    DECLARE FUNC BYTE, PARM ADDRESS;
END MON1;

/* Print character */
PRINT$CHAR: PROCEDURE(C);
    DECLARE C BYTE;
    CALL MON1(2, C);
END PRINT$CHAR;

/* Print string */
PRINT$STR: PROCEDURE(S);
    DECLARE S ADDRESS;
    CALL MON1(9, S);
END PRINT$STR;

/* Print newline */
CRLF: PROCEDURE;
    CALL PRINT$CHAR(CR);
    CALL PRINT$CHAR(LF);
END CRLF;

/* Print unsigned number */
PRINT$NUM: PROCEDURE(N);
    DECLARE N ADDRESS;
    DECLARE BUFFER(6) BYTE;
    DECLARE I BYTE;

    IF N = 0 THEN DO;
        CALL PRINT$CHAR('0');
        RETURN;
    END;

    I = 0;
    DO WHILE N > 0;
        BUFFER(I) = (N MOD 10) + '0';
        N = N / 10;
        I = I + 1;
    END;

    DO WHILE I > 0;
        I = I - 1;
        CALL PRINT$CHAR(BUFFER(I));
    END;
END PRINT$NUM;

/* Print test result */
PRINT$TEST: PROCEDURE(NAME, VALUE);
    DECLARE NAME ADDRESS;
    DECLARE VALUE ADDRESS;
    CALL PRINT$STR(NAME);
    CALL PRINT$CHAR(' ');
    CALL PRINT$NUM(VALUE);
    CALL CRLF;
END PRINT$TEST;

/* ================================================================
 * LITERALLY DECLARATIONS FOR TESTING
 * ================================================================ */

/* Size constants */
DECLARE SMALL$SIZE LITERALLY '4';
DECLARE MEDIUM$SIZE LITERALLY '8';
DECLARE LARGE$SIZE LITERALLY '16';

/* Value constants */
DECLARE CONST$TEN LITERALLY '10';
DECLARE CONST$HUNDRED LITERALLY '100';

/* Expression constants */
DECLARE DOUBLED LITERALLY 'CONST$TEN + CONST$TEN';

/* ================================================================
 * ARRAYS USING LITERALLY FOR DIMENSION
 * ================================================================ */

DECLARE SMALL$ARRAY(SMALL$SIZE) BYTE;
DECLARE MEDIUM$ARRAY(MEDIUM$SIZE) BYTE;
DECLARE LARGE$ARRAY(LARGE$SIZE) BYTE;

/* ================================================================
 * STRUCTURE WITH LITERALLY DIMENSION (Bug c05cd81)
 * ================================================================ */

DECLARE FRSIZE LITERALLY '36';  /* FCB record size */

/* This was the bug: parser failed on LITERALLY in struct member dimension */
DECLARE FCB$RECORD STRUCTURE(
    DRIVE BYTE,
    NAME(FRSIZE) BYTE,
    EXT(3) BYTE,
    EXTENT BYTE,
    S1 BYTE,
    S2 BYTE,
    RC BYTE,
    ALLOC(MEDIUM$SIZE) BYTE  /* Multiple LITERALLY in same struct */
);

/* ================================================================
 * TESTS
 * ================================================================ */

TEST$ARRAY$DIM: PROCEDURE;
    DECLARE I BYTE;

    /* Fill arrays using LITERALLY-sized bounds */
    DO I = 0 TO SMALL$SIZE - 1;
        SMALL$ARRAY(I) = I + 1;
    END;

    DO I = 0 TO MEDIUM$SIZE - 1;
        MEDIUM$ARRAY(I) = I * 2;
    END;

    DO I = 0 TO LARGE$SIZE - 1;
        LARGE$ARRAY(I) = I;
    END;

    /* Verify arrays */
    CALL PRINT$TEST(.'sm_0 $', SMALL$ARRAY(0));      /* Expected: 1 */
    CALL PRINT$TEST(.'sm_3 $', SMALL$ARRAY(3));      /* Expected: 4 */

    CALL PRINT$TEST(.'md_0 $', MEDIUM$ARRAY(0));     /* Expected: 0 */
    CALL PRINT$TEST(.'md_7 $', MEDIUM$ARRAY(7));     /* Expected: 14 */

    CALL PRINT$TEST(.'lg_0 $', LARGE$ARRAY(0));      /* Expected: 0 */
    CALL PRINT$TEST(.'lg_15 $', LARGE$ARRAY(15));    /* Expected: 15 */
END TEST$ARRAY$DIM;

TEST$STRUCT$DIM: PROCEDURE;
    DECLARE I BYTE;

    /* Initialize FCB structure */
    FCB$RECORD.DRIVE = 0;
    FCB$RECORD.EXTENT = 5;
    FCB$RECORD.RC = 10;

    /* Fill NAME using LITERALLY dimension */
    DO I = 0 TO FRSIZE - 1;
        FCB$RECORD.NAME(I) = 'A' + (I MOD 26);
    END;

    /* Fill EXT */
    FCB$RECORD.EXT(0) = 'C';
    FCB$RECORD.EXT(1) = 'O';
    FCB$RECORD.EXT(2) = 'M';

    /* Fill ALLOC using LITERALLY dimension */
    DO I = 0 TO MEDIUM$SIZE - 1;
        FCB$RECORD.ALLOC(I) = I + 100;
    END;

    /* Verify structure access */
    CALL PRINT$TEST(.'fcb_drv $', FCB$RECORD.DRIVE);    /* Expected: 0 */
    CALL PRINT$TEST(.'fcb_ext $', FCB$RECORD.EXTENT);   /* Expected: 5 */
    CALL PRINT$TEST(.'fcb_rc $', FCB$RECORD.RC);        /* Expected: 10 */
    CALL PRINT$TEST(.'fcb_nm0 $', FCB$RECORD.NAME(0));  /* Expected: 65 ('A') */
    CALL PRINT$TEST(.'fcb_nm8 $', FCB$RECORD.NAME(8));  /* Expected: 73 ('I') */
    CALL PRINT$TEST(.'fcb_ex0 $', FCB$RECORD.EXT(0));   /* Expected: 67 ('C') */
    CALL PRINT$TEST(.'fcb_al0 $', FCB$RECORD.ALLOC(0)); /* Expected: 100 */
    CALL PRINT$TEST(.'fcb_al7 $', FCB$RECORD.ALLOC(7)); /* Expected: 107 */
END TEST$STRUCT$DIM;

TEST$EXPR$CONST: PROCEDURE;
    DECLARE RESULT ADDRESS;

    /* LITERALLY in expressions */
    RESULT = CONST$TEN;
    CALL PRINT$TEST(.'lit_10 $', RESULT);            /* Expected: 10 */

    RESULT = CONST$HUNDRED;
    CALL PRINT$TEST(.'lit_100 $', RESULT);           /* Expected: 100 */

    RESULT = CONST$TEN + CONST$HUNDRED;
    CALL PRINT$TEST(.'lit_sum $', RESULT);           /* Expected: 110 */

    RESULT = CONST$TEN * CONST$TEN;
    CALL PRINT$TEST(.'lit_mul $', RESULT);           /* Expected: 100 */

    /* Nested LITERALLY expansion */
    RESULT = DOUBLED;
    CALL PRINT$TEST(.'lit_dbl $', RESULT);           /* Expected: 20 */
END TEST$EXPR$CONST;

TEST$LOOP$BOUND: PROCEDURE;
    DECLARE I BYTE;
    DECLARE SUM ADDRESS;

    /* LITERALLY as loop bound */
    SUM = 0;
    DO I = 1 TO CONST$TEN;
        SUM = SUM + I;
    END;
    CALL PRINT$TEST(.'loop_b $', SUM);               /* Expected: 55 (1+2+...+10) */

    /* LITERALLY in loop step expression */
    SUM = 0;
    I = 0;
    DO WHILE I < CONST$HUNDRED;
        SUM = SUM + 1;
        I = I + CONST$TEN;
    END;
    CALL PRINT$TEST(.'loop_s $', SUM);               /* Expected: 10 */
END TEST$LOOP$BOUND;

/* ================================================================
 * MAIN
 * ================================================================ */

MAIN: PROCEDURE;
    CALL PRINT$STR(.'LITERALLY Tests$');
    CALL CRLF;
    CALL PRINT$STR(.'===============$');
    CALL CRLF;
    CALL CRLF;

    CALL TEST$ARRAY$DIM;
    CALL TEST$STRUCT$DIM;
    CALL TEST$EXPR$CONST;
    CALL TEST$LOOP$BOUND;

    CALL CRLF;
    CALL PRINT$STR(.'Done.$');
    CALL CRLF;
END MAIN;

CALL MAIN;

END TEST$LITERALLY;

EOF
